# MapLibre style URL — defaults to CartoCDN dark-matter (free, no signup).
# Other free options:
#   https://basemaps.cartocdn.com/gl/voyager-gl-style/style.json     (light, label-rich)
#   https://basemaps.cartocdn.com/gl/positron-gl-style/style.json    (very light)
# For Mapbox-hosted styles, supply a full URL with your access token in the query string.
VITE_MAP_STYLE=

# Override the API base if running the backend on a non-default host/port.
# Defaults to "" which uses the Vite proxy at /api.
VITE_API_BASE=
