# Override the data root if running from outside the repo. Defaults to <repo>/data.
# SEISMO_DATA_ROOT=/absolute/path/to/Seismo/data

# OpenTopography API key for the /api/terrain endpoint.
# Free at https://portal.opentopography.org/ (1,000 req/day).
# If unset, the terrain service returns a deterministic synthetic heightfield
# flagged `synthetic_for_demo: true` — the demo stays runnable offline.
# SEISMO_OPENTOPO_API_KEY=your_key_here
